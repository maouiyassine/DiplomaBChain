# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ── Comptes Besu (pré-financés dans genesis.json) ──────────────
ADMIN_PRIVATE_KEY=0xVOTRE_CLE_ADMIN
ADMIN_ADDRESS=0xVOTRE_ADRESSE_ADMIN

MINISTRY_PRIVATE_KEY=0xVOTRE_CLE_MINISTERE
MINISTRY_ADDRESS=0xVOTRE_ADRESSE_MINISTERE

UNIVERSITY_PRIVATE_KEY=0xVOTRE_CLE_UNIVERSITE
UNIVERSITY_ADDRESS=0xVOTRE_ADRESSE_UNIVERSITE

STUDENT_PRIVATE_KEY=0xVOTRE_CLE_ETUDIANT
STUDENT_ADDRESS=0xVOTRE_ADRESSE_ETUDIANT

# ── IPFS (optionnel) ───────────────────────────────────────────
# Laisser vide pour utiliser le serveur local
# IPFS_API_URL=http://127.0.0.1:5001/api/v0

# ── Rétrocompatibilité ─────────────────────────────────────────
BESU_TEST_PRIVATE_KEY=0xVOTRE_CLE_ADMIN
