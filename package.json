{
  "name": "diploma-verification",
  "version": "1.0.0",
  "private": true,
  "description": "Diploma verification system frontend and optional Node server",
  "type": "module",
  "scripts": {
    "dev": "bash start.sh",
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "serve": "node server.js",
    "test": "jest",
    "contract:test": "cd smart-contracts && npx hardhat test",
    "ipfs:start": "ipfs daemon",
    "besu:start": "cd blockchain && bash start-besu.sh",
    "besu:deploy": "cd smart-contracts && npx hardhat run scripts/deploy-besu.js --network besuLocal",
    "besu:setup": "cd smart-contracts && npx hardhat run scripts/setup.js --network besuLocal"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "ipfs-http-client": "^59.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@nomicfoundation/hardhat-toolbox": "hh2",
    "@openzeppelin/contracts": "^5.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^29.6.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "dotenv-webpack": "^9.0.0",
    "hardhat": "^2.22.2",
    "html-webpack-plugin": "^5.5.1",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^30.3.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.0"
  }
}
